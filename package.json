{
  "name": "react-wash-icons",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/react-wash-icons.cjs",
  "module": "./dist/react-wash-icons.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/react-wash-icons.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/react-wash-icons.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "fast-xml-parser": "^5.5.9",
    "react": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "scripts": {
    "generate": "tsx scripts/generate-icons.ts",
    "build": "npm run generate && vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build"
  }
}
